# Database Configuration
# Скопируйте этот файл в .env и заполните своими значениями
DATABASE_URL="postgresql://radiodetali:radiodetali_secret@localhost:5432/radiodetali?schema=public"

# Docker Compose variables
POSTGRES_USER=radiodetali
POSTGRES_PASSWORD=radiodetali_secret
POSTGRES_DB=radiodetali

# Admin Authentication
# Пароль для входа в админ-панель
ADMIN_PASSWORD="your_secure_password_here"

# Public URL (для Open Graph изображений и sitemap)
# Используется при сборке Docker образа
NEXT_PUBLIC_BASE_URL="https://драгсоюз.рф"

# JivoSite — онлайн-чат (ID виджета из кабинета Jivo)
NEXT_PUBLIC_JIVO_WIDGET_ID="mL1h2xDSrD"
